generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id_role    Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(100)
  created_at DateTime @default(now())

  users      User[]

  @@map("Role")
}

model User {
  id_user    Int       @id @default(autoincrement())
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  full_name  String    @db.VarChar(255)
  id_role    Int
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?

  role       Role       @relation(fields: [id_role], references: [id_role])
  favorites  UserEvent[]
  purchases  Purchase[]

  @@map("User")
}

model Category {
  id_category Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(255)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  deleted_at  DateTime?

  events      Event[]

  @@map("Category")
}

model Event {
  id_event    Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(255)
  id_category Int
  price       Float     @default(0)
  description String
  location    String    @db.VarChar(255)
  date_time   DateTime?
  capacity    Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt
  deleted_at  DateTime?

  category    Category       @relation(fields: [id_category], references: [id_category])
  images      EventImage[]
  history     EventHistory[]
  interests   Interest[]
  favorites   UserEvent[]
  purchases   Purchase[]

  @@map("Event")
}

model EventImage {
  id_image  Int    @id @default(autoincrement())
  id_event  Int
  image_url String @db.VarChar(255)
  type      String @default("poster") @db.VarChar(50)

  event     Event  @relation(fields: [id_event], references: [id_event], onDelete: Cascade)

  @@map("EventImage")
}

model EventHistory {
  id_history  Int       @id @default(autoincrement())
  id_event    Int
  name        String?   @db.VarChar(255)
  id_category Int?
  price       Float?
  description String?
  location    String?   @db.VarChar(255)
  date_time   DateTime?
  changed_at  DateTime  @default(now())

  event       Event     @relation(fields: [id_event], references: [id_event])

  @@map("EventHistory")
}

model Interest {
  id_interest     Int      @id @default(autoincrement())
  id_event        Int
  user_identifier String   @db.VarChar(255)
  created_at      DateTime @default(now())

  event           Event    @relation(fields: [id_event], references: [id_event])

  @@unique([id_event, user_identifier])
  @@map("Interest")
}

model UserEvent {
  id_favorite Int      @id @default(autoincrement())
  id_user     Int
  id_event    Int
  created_at  DateTime @default(now())

  user        User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  event       Event    @relation(fields: [id_event], references: [id_event], onDelete: Cascade)

  @@unique([id_user, id_event])
  @@index([id_user])
  @@index([id_event])
  @@map("UserEvent")
}

model Purchase {
  id_purchase Int      @id @default(autoincrement())
  id_user     Int
  id_event    Int
  quantity    Int
  unit_price  Float
  /// Campo generado por la BD (quantity * unit_price). Solo lectura — no incluir en create/update.
  total_price Float?
  status      String   @default("pending") @db.VarChar(20)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  user        User     @relation(fields: [id_user], references: [id_user], onDelete: Cascade)
  event       Event    @relation(fields: [id_event], references: [id_event], onDelete: Cascade)

  @@index([id_user])
  @@index([id_event])
  @@index([status])
  @@map("Purchase")
}
